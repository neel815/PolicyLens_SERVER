# ============================================================================
# PRODUCTION ENVIRONMENT TEMPLATE
# Copy this file to .env and fill in all values
# ============================================================================

# Application Environment
# Options: development, staging, production
ENV=production
DEBUG=false

# ============================================================================
# DATABASE CONFIGURATION - CHANGE ALL VALUES FOR PRODUCTION
# ============================================================================
DB_ENGINE=postgresql
DB_USER=your_postgres_user
DB_PASSWORD=your_strong_password_here
DB_HOST=your-db-host.example.com
DB_PORT=5432
DB_NAME=policylens_prod

# Full PostgreSQL URL (auto-constructed from above, but can be overridden)
# Format: postgresql://user:password@host:port/database
# ⚠️  CRITICAL: Use a strong password. Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
DATABASE_URL=postgresql://your_postgres_user:your_strong_password_min_32_characters@your-db-host.example.com:5432/policylens_prod

# Database password (used in docker-compose)
DB_PASSWORD=your_strong_password_min_32_characters

# ============================================================================
# SECURITY - CRITICAL FOR PRODUCTION
# ============================================================================

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# MUST be 32+ characters for production
SECRET_KEY=your_secret_key_min_32_characters_here

# JWT Algorithm
ALGORITHM=HS256

# ============================================================================
# CORS CONFIGURATION
# List production domains separated by commas (NO wildcards)
# ============================================================================
CORS_ORIGINS=https://app.yourdomain.com,https://yourdomain.com

# ============================================================================
# API CONFIGURATION
# ============================================================================
APP_NAME=PolicyLens API
APP_VERSION=1.0.0
APP_DESCRIPTION=AI-Powered Insurance Policy Analysis Platform

SERVER_HOST=0.0.0.0
SERVER_PORT=8000
RELOAD=false

# ============================================================================
# DATABASE POOL CONFIGURATION
# Tune these based on concurrent users and available resources
# ============================================================================
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# ============================================================================
# EXTERNAL API KEYS
# ============================================================================

# Gemini API Key (for policy analysis)
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API Key (optional, for alternative LLM)
GROQ_API_KEY=your_groq_api_key_here

# ============================================================================
# RATE LIMITING
# Format: "requests/minute" (e.g., "5/minute" = 5 requests per minute)
# ============================================================================
RATE_LIMIT_ANALYZE=5/minute
RATE_LIMIT_BATTLE=10/minute
RATE_LIMIT_REGISTER=3/hour

# ============================================================================
# MONITORING & LOGGING
# ============================================================================
LOG_LEVEL=INFO
LOG_FILE=logs/api.log
LOG_MAX_SIZE=10485760

# ============================================================================
# TLS/SSL CONFIGURATION (for production)
# ============================================================================
# Set to true to enable HTTPS redirect
ENABLE_HTTPS_REDIRECT=true

# ============================================================================
# OPTIONAL: SENTRY ERROR TRACKING
# ============================================================================
# SENTRY_DSN=your_sentry_dsn_here

# ============================================================================
# OPTIONAL: RATE LIMITING SERVICE
# ============================================================================
# REDIS_URL=redis://localhost:6379/0

