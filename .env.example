# FastAPI Backend Configuration - Example
# Copy this to .env and update values as needed

ENV=development
DEBUG=true

# Database Configuration
DB_ENGINE=postgresql
DB_USER=postgres
DB_PASSWORD=root@123
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=policylens
DATABASE_URL=postgresql://postgres:root%40123@127.0.0.1:5432/policylens

# Application Settings
APP_NAME=PolicyLens API
APP_VERSION=1.0.0
APP_DESCRIPTION=PolicyLens Backend API

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
RELOAD=true

# Security
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Logging
LOG_LEVEL=INFO
ENABLE_LOGGING=true

# Database Pool
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600
